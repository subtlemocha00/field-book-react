{
  "name": "@field-book/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev --local --port 8787",
    "build": "tsc -b",
    "deploy": "wrangler deploy",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "migrate:local": "wrangler d1 migrations apply field-book-local --local"
  },
  "dependencies": {
    "@field-book/contracts": "workspace:*",
    "@field-book/domain": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20240815.0",
    "typescript": "^5.5.4",
    "vitest": "2.0.5",
    "wrangler": "^3.72.0"
  }
}
