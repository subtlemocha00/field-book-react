{
  "name": "field-book",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm-run-all --parallel dev:web dev:api",
    "dev:web": "npm run dev --workspace @field-book/web",
    "dev:api": "npm run dev --workspace @field-book/api",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "tsc -b",
    "verify:phase1": "node scripts/verify-phase1.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.9.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}